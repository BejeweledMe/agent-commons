{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-commons:schema:ledger-anchor:v1",
  "x-schema-name": "commons.ledger_anchor.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "workspace_id",
    "scope_id",
    "generation",
    "events",
    "observed_at"
  ],
  "properties": {
    "schema": {"const": "commons.ledger_anchor.v1"},
    "workspace_id": {"type": "string", "minLength": 1},
    "scope_id": {"$ref": "urn:agent-commons:schema:common:v1#/$defs/sha256"},
    "generation": {"type": "integer", "minimum": 0},
    "events": {
      "type": "object",
      "propertyNames": {"pattern": "^events/[0-9]{4}/[0-9]{2}/[0-9]{2}/evt\\.[0-9A-HJKMNP-TV-Z]{26}\\.json$"},
      "additionalProperties": {"$ref": "urn:agent-commons:schema:common:v1#/$defs/sha256"}
    },
    "observed_at": {"type": "string", "format": "date-time"}
  }
}
