{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-commons:schema:common:v1",
  "x-schema-name": "commons.common.v1",
  "$defs": {
    "typedRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },
    "revisionBoundRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "revision"],
      "properties": {
        "ref": {"$ref": "#/$defs/typedRef"},
        "revision": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "predicate", "object"],
      "properties": {
        "subject": {"$ref": "#/$defs/typedRef"},
        "predicate": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "object": {"$ref": "#/$defs/typedRef"}
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
