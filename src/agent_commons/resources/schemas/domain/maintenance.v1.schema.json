{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-commons:schema:payload:maintenance:v1",
  "x-schema-name": "commons.payload.maintenance.v1",
  "x-event-types": ["event.corrected", "event.invalidated", "event.invalidation_revoked"],
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "target_event_id": {"type": "string", "pattern": "^evt\\.[0-9A-HJKMNP-TV-Z]{26}$"},
    "expected_target_sha256": {"$ref": "urn:agent-commons:schema:common:v1#/$defs/sha256"},
    "replacement_payload": {"type": "object"},
    "superseded_correction_event_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^evt\\.[0-9A-HJKMNP-TV-Z]{26}$"}
    },
    "target_ref": {"$ref": "urn:agent-commons:schema:common:v1#/$defs/typedRef"},
    "reason": {"type": "string", "minLength": 1},
    "invalidation_event_id": {"type": "string", "pattern": "^evt\\.[0-9A-HJKMNP-TV-Z]{26}$"},
    "extensions": {"type": "object"}
  }
}
