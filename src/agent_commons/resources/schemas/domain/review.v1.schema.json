{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-commons:schema:payload:review:v1",
  "x-schema-name": "commons.payload.review.v1",
  "x-event-types": ["review.requested", "review.completed"],
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "review_id": {"type": "string", "pattern": "^review\\.[0-9A-HJKMNP-TV-Z]{26}$"},
    "target_ref": {"$ref": "urn:agent-commons:schema:common:v1#/$defs/typedRef"},
    "target_revision": {"type": "string", "pattern": "^evt\\.[0-9A-HJKMNP-TV-Z]{26}$"},
    "criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "independent": {"type": "boolean"},
    "expected_revision": {"type": "string", "pattern": "^evt\\.[0-9A-HJKMNP-TV-Z]{26}$"},
    "verdict": {"enum": ["approved", "changes_requested", "rejected", "abstained"]},
    "summary": {"type": "string", "minLength": 1},
    "evidence_refs": {"type": "array", "items": {"$ref": "urn:agent-commons:schema:common:v1#/$defs/revisionBoundRef"}},
    "extensions": {"type": "object"}
  }
}
