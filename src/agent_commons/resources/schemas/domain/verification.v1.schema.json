{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-commons:schema:payload:verification:v1",
  "x-schema-name": "commons.payload.verification.v1",
  "x-event-types": ["verification.recorded"],
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "verification_id": {"type": "string", "pattern": "^verification\\.[0-9A-HJKMNP-TV-Z]{26}$"},
    "target_ref": {"$ref": "urn:agent-commons:schema:common:v1#/$defs/typedRef"},
    "target_revision": {"type": "string", "pattern": "^evt\\.[0-9A-HJKMNP-TV-Z]{26}$"},
    "claim": {"type": "string", "minLength": 1},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "urn:agent-commons:schema:common:v1#/$defs/revisionBoundRef"}},
    "method": {"type": "string", "minLength": 1},
    "outcome": {"type": "string", "minLength": 1},
    "extensions": {"type": "object"}
  }
}
