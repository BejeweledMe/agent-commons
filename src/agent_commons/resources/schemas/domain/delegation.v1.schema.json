{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-commons:schema:payload:delegation:v1",
  "x-schema-name": "commons.payload.delegation.v1",
  "x-event-types": [
    "delegation.requested",
    "delegation.started",
    "delegation.input_needed",
    "delegation.resumed",
    "delegation.succeeded",
    "delegation.failed",
    "delegation.cancelled",
    "delegation.recovered",
    "delegation.timed_out",
    "delegation.needs_operator"
  ],
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "delegation_id": {
      "type": "string",
      "pattern": "^delegation\\.[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "expected_revision": {
      "type": "string",
      "pattern": "^evt\\.[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "target_ref": {
      "$ref": "urn:agent-commons:schema:common:v1#/$defs/typedRef"
    },
    "target_revision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "target_profile": {
      "enum": [
        "codex-builder",
        "codex-independent-reviewer",
        "claude-builder",
        "claude-independent-reviewer"
      ]
    },
    "purpose": {
      "enum": ["implementation", "independent_review", "verification"]
    },
    "parent_session_id": {
      "type": "string",
      "pattern": "^session\\.[a-f0-9]{32}$"
    },
    "parent_delegation_id": {
      "type": "string",
      "pattern": "^delegation\\.[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "root_delegation_id": {
      "type": "string",
      "pattern": "^delegation\\.[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "depth": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8
    },
    "limits": {
      "$ref": "#/$defs/limits"
    },
    "child_session_id": {
      "type": "string",
      "pattern": "^session\\.[a-f0-9]{32}$"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "maximum": 32
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8192
    },
    "resolution": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8192
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8192
    },
    "reason_code": {
      "enum": [
        "provider_unavailable",
        "provider_auth",
        "rate_limited",
        "policy_denied",
        "launch_failed",
        "runtime_error",
        "invalid_result",
        "integrity_error",
        "budget_exhausted",
        "orphaned",
        "unknown"
      ]
    },
    "result_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "urn:agent-commons:schema:common:v1#/$defs/typedRef"
      }
    }
  },
  "$defs": {
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_depth",
        "wall_time_seconds",
        "max_attempts",
        "max_concurrency",
        "budget"
      ],
      "properties": {
        "max_depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8
        },
        "wall_time_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "max_concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["unit", "limit"],
          "properties": {
            "unit": {
              "enum": ["tokens", "micro_usd", "provider_units"]
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000000000000
            }
          }
        }
      }
    }
  }
}
