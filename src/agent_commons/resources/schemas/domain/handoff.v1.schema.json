{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-commons:schema:payload:handoff:v1",
  "x-schema-name": "commons.payload.handoff.v1",
  "x-event-types": ["handoff.created", "handoff.acknowledged"],
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "handoff_id": {"type": "string", "pattern": "^handoff\\.[0-9A-HJKMNP-TV-Z]{26}$"},
    "to": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "completed": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "active": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "next_actions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "risks": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "open_questions": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "related_refs": {"type": "array", "items": {"$ref": "urn:agent-commons:schema:common:v1#/$defs/typedRef"}},
    "expected_revision": {"type": "string", "pattern": "^evt\\.[0-9A-HJKMNP-TV-Z]{26}$"},
    "note": {"type": "string", "minLength": 1},
    "extensions": {"type": "object"}
  }
}
